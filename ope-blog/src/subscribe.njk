---
layout: base.njk
title: Subscribe
permalink: subscribe/
---
<h2>Subscribe</h2>
<p>Get access to all posts, including subscriber-only content, in any OPE-compatible reader.</p>

{% for plan in ope.plans %}
<div style="margin: 2rem 0; padding: 1.5rem; border: 1px solid var(--border); border-radius: 8px;">
  <h3 style="margin-bottom: 0.5rem;">{{ plan.name }}: ${{ (plan.amount / 100) | round(2) }}{% if plan.id == "monthly" %}/mo{% elif plan.id == "annual" %}/yr{% endif %}</h3>
  <p style="color: var(--muted); font-size: 0.9rem; margin-bottom: 1rem;">Full access to all content.{% if plan.id == "monthly" %} Cancel anytime.{% elif plan.id == "annual" %} Best value.{% endif %}</p>
  <a href="#" class="cta" style="display: inline-block; background: var(--accent); color: #fff; padding: 0.5rem 1.25rem; border-radius: 6px; font-weight: 500;">Subscribe</a>
</div>
{% endfor %}

<div style="margin-top: 2rem; font-size: 0.85rem; color: var(--muted);">
  <p>This blog uses <a href="https://feedspec.org">Open Portable Entitlement (OPE)</a>.
  Your subscription works in any OPE-compatible reader app, not just this website.</p>
  <p style="margin-top: 0.5rem;">Supported grant types: {{ ope.grantsSupported | join(", ") }}</p>
</div>
