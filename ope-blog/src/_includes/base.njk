<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title | default("OPE Demo Blog") }}</title>
  <link rel="alternate" type="application/json" href="/feed.json" title="JSON Feed">
  <link rel="alternate" type="application/atom+xml" href="/feed.xml" title="Atom Feed">
  <style>
    :root { --text: #1a1a1a; --muted: #666; --bg: #fff; --accent: #2563eb; --border: #e5e7eb; --gated-bg: #fefce8; --gated-border: #fbbf24; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--text); background: var(--bg); line-height: 1.7; max-width: 640px; margin: 0 auto; padding: 2rem 1rem; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    header { margin-bottom: 3rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    header h1 { font-size: 1.25rem; font-weight: 600; }
    header nav { margin-top: 0.5rem; font-size: 0.875rem; color: var(--muted); }
    header nav a { margin-right: 1rem; }
    article { margin-bottom: 3rem; }
    article h2 { font-size: 1.5rem; margin-bottom: 0.25rem; }
    article .meta { font-size: 0.875rem; color: var(--muted); margin-bottom: 1rem; }
    article .content { margin-bottom: 1rem; }
    article .content p { margin-bottom: 1rem; }
    .gated-notice { background: var(--gated-bg); border: 1px solid var(--gated-border); border-radius: 8px; padding: 1.25rem; margin: 1.5rem 0; }
    .gated-notice .stats { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.75rem; }
    .gated-notice .cta { display: inline-block; background: var(--accent); color: #fff; padding: 0.5rem 1.25rem; border-radius: 6px; font-weight: 500; font-size: 0.9rem; }
    .gated-notice .cta:hover { text-decoration: none; opacity: 0.9; }
    .tag { display: inline-block; font-size: 0.75rem; background: #f3f4f6; color: var(--muted); padding: 0.125rem 0.5rem; border-radius: 4px; margin-right: 0.25rem; }
    .tag.gated { background: #fef3c7; color: #92400e; }
    footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.8rem; color: var(--muted); }
    .ope-badge { font-size: 0.75rem; background: #eff6ff; color: var(--accent); padding: 0.125rem 0.5rem; border-radius: 4px; font-weight: 500; }
  </style>
</head>
<body>
  <header>
    <h1><a href="/">OPE Demo Blog</a></h1>
    <nav>
      <a href="/">Posts</a>
      <a href="/feed.json">JSON Feed</a>
      <a href="/subscribe/">Subscribe</a>
      <span class="ope-badge">OPE-enabled</span>
    </nav>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>Powered by <a href="https://www.11ty.dev/">Eleventy</a> + <a href="https://feedspec.org">OPE</a></p>
  </footer>
</body>
</html>
